{
    "name": "Java 17 Development (TPO)",
    "image": "mcr.microsoft.com/devcontainers/java:17-bookworm", 
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17",
            "installMaven": "true"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vmware.vscode-spring-boot-dashboard",
                "vscjava.vscode-spring-boot-extension-pack",
                "vscjava.vscode-lombok"
            ]
        }
    },
    "forwardPorts": [8080],
    "postCreateCommand": "mvn clean install -DskipTests"
}